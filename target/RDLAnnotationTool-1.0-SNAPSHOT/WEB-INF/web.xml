<?xml version="1.0" encoding="UTF-8"?>
<web-app version="3.1" xmlns="http://xmlns.jcp.org/xml/ns/javaee" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:schemaLocation="http://xmlns.jcp.org/xml/ns/javaee http://xmlns.jcp.org/xml/ns/javaee/web-app_3_1.xsd">
    <servlet>
        <servlet-name>ConvertJSONtoRDFTriples</servlet-name>
        <servlet-class>servlets.ConvertJSONtoRDFTriples</servlet-class>
    </servlet>
    <servlet>
        <servlet-name>ChatGPTAPI</servlet-name>
        <servlet-class>servlets.ChatGPTAPI</servlet-class>
    </servlet>
    <servlet>
        <servlet-name>readPrompt</servlet-name>
        <servlet-class>servlets.readPrompt</servlet-class>
    </servlet>
    <servlet>
        <servlet-name>EntitiesTable</servlet-name>
        <servlet-class>servlets.EntitiesTable</servlet-class>
    </servlet>
    <servlet>
        <servlet-name>DeepSeekAPI</servlet-name>
        <servlet-class>servlets.DeepSeekAPI</servlet-class>
    </servlet>
    <servlet>
        <servlet-name>GeminiAPI</servlet-name>
        <servlet-class>servlets.GeminiAPI</servlet-class>
    </servlet>
    <servlet>
        <servlet-name>ValidateTriples</servlet-name>
        <servlet-class>servlets.ValidateTriples</servlet-class>
    </servlet>
    <servlet>
        <servlet-name>ProduceDrawIOServlet</servlet-name>
        <servlet-class>servlets.ProduceDrawIOServlet</servlet-class>
    </servlet>
    <servlet>
        <servlet-name>DownloadEntitiesNTServlet</servlet-name>
        <servlet-class>servlets.DownloadEntitiesNTServlet</servlet-class>
    </servlet>
    <servlet>
        <servlet-name>readRelationPrompt</servlet-name>
        <servlet-class>servlets.readRelationPrompt</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>ConvertJSONtoRDFTriples</servlet-name>
        <url-pattern>/ConvertJSONtoRDFTriples</url-pattern>
    </servlet-mapping>
    <servlet-mapping>
        <servlet-name>ChatGPTAPI</servlet-name>
        <url-pattern>/ChatGPTAPI</url-pattern>
    </servlet-mapping>
    <servlet-mapping>
        <servlet-name>readPrompt</servlet-name>
        <url-pattern>/readPrompt</url-pattern>
    </servlet-mapping>
    <servlet-mapping>
        <servlet-name>EntitiesTable</servlet-name>
        <url-pattern>/EntitiesTable</url-pattern>
    </servlet-mapping>
    <servlet-mapping>
        <servlet-name>DeepSeekAPI</servlet-name>
        <url-pattern>/DeepSeekAPI</url-pattern>
    </servlet-mapping>
    <servlet-mapping>
        <servlet-name>GeminiAPI</servlet-name>
        <url-pattern>/GeminiAPI</url-pattern>
    </servlet-mapping>
    <servlet-mapping>
        <servlet-name>ValidateTriples</servlet-name>
        <url-pattern>/ValidateTriples</url-pattern>
    </servlet-mapping>
    <servlet-mapping>
        <servlet-name>ProduceDrawIOServlet</servlet-name>
        <url-pattern>/ProduceDrawIOServlet</url-pattern>
    </servlet-mapping>
    <servlet-mapping>
        <servlet-name>DownloadEntitiesNTServlet</servlet-name>
        <url-pattern>/DownloadEntitiesNTServlet</url-pattern>
    </servlet-mapping>
    <servlet-mapping>
        <servlet-name>readRelationPrompt</servlet-name>
        <url-pattern>/readRelationPrompt</url-pattern>
    </servlet-mapping>
    <session-config>
        <session-timeout>
            30
        </session-timeout>
    </session-config>
</web-app>
